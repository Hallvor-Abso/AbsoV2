# =============================================================================
#  BOT DISCORD — Absolution
# =============================================================================
#  Copie ce fichier en ".env" (à la racine du projet) et remplis les valeurs.
#  En production (Railway/Fly/VPS), renseigne ces variables dans l'hébergeur.
# =============================================================================

# Token du bot : Discord Developer Portal → ton application → onglet "Bot" → Reset Token
DISCORD_BOT_TOKEN=""

# Application (client) ID : Discord Developer Portal → "General Information" → Application ID
DISCORD_CLIENT_ID=""

# (Optionnel) ID de ton serveur Discord → commandes mises à jour instantanément.
# Pour l'obtenir : Discord → Paramètres → Avancés → Mode développeur, puis
# clic droit sur le serveur → "Copier l'identifiant du serveur".
# Laisse vide pour des commandes globales (propagation jusqu'à 1 h).
DISCORD_GUILD_ID=""

# MÊME base de données que le site (copie la DATABASE_URL du site).
DATABASE_URL=""

# Secret partagé avec le site pour les appels HTTP (site → bot). Génère une
# longue chaîne aléatoire et mets LA MÊME valeur côté site (BOT_HTTP_SECRET).
BOT_HTTP_SECRET=""

# (OPTIONNEL) Salon calendrier de SECOURS, utilisé seulement si un jeu n'a pas
# son propre salon. Normalement, on configure un salon PAR JEU directement dans
# l'admin du site (Jeux → « Salon Discord du calendrier »).
DISCORD_CALENDAR_CHANNEL_ID=""
