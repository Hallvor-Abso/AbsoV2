// =============================================================================
//  SCHÉMA PRISMA DU BOT — copie de ../../prisma/schema.prisma
// =============================================================================
//  ⚠️  À GARDER SYNCHRONISÉ avec le schéma du site (prisma/schema.prisma).
//  Le bot ne fait que LIRE la base ; ce fichier sert uniquement à générer le
//  client Prisma du bot. Pas de `directUrl` (aucune migration côté bot).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String?  @unique
  email        String?  @unique
  displayName  String?
  discord      String?
  discordId    String?  @unique
  passwordHash String
  role         Role     @default(VISITEUR)
  discordRoles String[] @default([])
  adminGames   Game[]   @relation("GameAdmins")
  applications Application[]
  createdAt    DateTime @default(now())
}

enum Role {
  VISITEUR
  MEMBRE
  ADMIN
  SUPER_ADMIN
}

model Game {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  logoUrl          String?
  coverImageUrl    String?
  color            String     @default("#4A9EFF")
  isActive         Boolean    @default(true)
  status           GameStatus @default(ACTIVE)
  order            Int        @default(0)
  discordCalendarChannelId    String?
  discordRecruitmentChannelId String?
  discordRecruitmentCategoryId String?
  discordRoleTag  String?

  raidTiers        RaidTier[]
  news             News[]
  recruitmentRoles RecruitmentRole[]
  recruitmentSlots RecruitmentSlot[]
  applications     Application[]
  memberMains      MemberMain[]
  events           Event[]
  admins           User[]     @relation("GameAdmins")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum GameStatus {
  ACTIVE
  UPCOMING
}

model RaidTier {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  expansion String?
  zoneId    Int?
  timerDone Boolean  @default(false)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    String
  bosses    Boss[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Boss {
  id            String     @id @default(cuid())
  name          String
  status        BossStatus @default(UNTESTED)
  firstKillDate DateTime?
  imageUrl      String?
  encounterId   Int?
  order         Int        @default(0)
  tier          RaidTier   @relation(fields: [tierId], references: [id], onDelete: Cascade)
  tierId        String

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

enum BossStatus {
  KILLED
  PROGRESSING
  UNTESTED
}

model News {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String
  imageUrl    String?
  featured    Boolean    @default(false)
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  game        Game?      @relation(fields: [gameId], references: [id], onDelete: SetNull)
  gameId      String?

  discordChannelId String?
  discordMessageId String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

model RecruitmentRole {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([gameId, name])
}

model RecruitmentSlot {
  id        String     @id @default(cuid())
  role      String
  className String
  status    SlotStatus @default(OPEN)
  note      String?
  order     Int        @default(0)
  game      Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    String

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum SlotStatus {
  OPEN
  LIMITED
  CLOSED
}

model Application {
  id            String            @id @default(cuid())
  pseudo        String
  discord       String?
  answers       Json? // réponses au formulaire personnalisé : [{ label, value }]
  characterId   String?
  className     String?
  role          String?
  server        String?
  experience    String?
  availability  String?
  logsUrl       String?
  motivation    String?
  status        ApplicationStatus @default(PENDING)
  internalNotes String?
  discordChannelId String?

  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId        String?
  lastOfficerMessageAt DateTime?
  candidateSeenAt      DateTime?

  game          Game?             @relation(fields: [gameId], references: [id], onDelete: SetNull)
  gameId        String?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum ApplicationStatus {
  PENDING
  DISCUSSING
  ACCEPTED
  REJECTED
}

model Event {
  id               String    @id @default(cuid())
  title            String
  description      String?
  startDate        DateTime
  endDate          DateTime?
  type             String    @default("RAID")
  game             Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId           String

  discordChannelId String?
  discordMessageId String?
  reminder24hSentAt DateTime?
  reminder1hSentAt  DateTime?
  rosterChannelId  String?
  rosterMessageId  String?
  rosterMessage    String?
  rosterDmAt       DateTime?
  rosterDmSentAt   DateTime?
  seriesId         String?
  announceAt       DateTime?
  seriesOpen       Boolean   @default(false)
  recurrence       String?
  publishWeekday   Int?
  publishHour      Int?
  publishMinute    Int?
  signups          EventSignup[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model EventSignup {
  id          String       @id @default(cuid())
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String
  discordId   String
  displayName String
  status      SignupStatus @default(GOING)
  source      String       @default("discord")
  selected    Boolean      @default(false)

  role        String?
  classId     String?
  className   String?
  spec        String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([eventId, discordId])
}

enum SignupStatus {
  GOING
  MAYBE
  DECLINED
}

model TwitchCommand {
  id              String   @id @default(cuid())
  name            String   @unique
  response        String
  enabled         Boolean  @default(true)
  cooldownSeconds Int      @default(5)
  userLevel       String   @default("EVERYONE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TwitchTimer {
  id              String   @id @default(cuid())
  name            String
  message         String
  intervalMinutes Int      @default(15)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TwitchModConfig {
  id            String   @id @default("default")
  blockLinks    Boolean  @default(false)
  permitSeconds Int      @default(60)
  capsEnabled   Boolean  @default(false)
  capsMinLength Int      @default(12)
  capsPercent   Int      @default(70)
  blacklist     String[] @default([])
  timeoutSeconds Int      @default(30)
  warnMessage   String?
  modsImmune    Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

model MemberMain {
  id        String   @id @default(cuid())
  discordId String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    String
  role      String
  classId   String
  className String
  specId    String
  spec      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([discordId, gameId])
}

model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
