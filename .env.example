# =============================================================================
#  FICHIER DE CONFIGURATION — Site de la guilde Absolution
# =============================================================================
#
#  COMMENT UTILISER CE FICHIER :
#  1. Fais une COPIE de ce fichier et nomme-la ".env" (sans le ".example")
#  2. Remplis chaque valeur ci-dessous en suivant les explications
#  3. Ne partage JAMAIS ton fichier ".env" : il contient des mots de passe
#
#  (Le README explique pas-à-pas où trouver chacune de ces valeurs.)
# =============================================================================


# -----------------------------------------------------------------------------
#  1. BASE DE DONNÉES (PostgreSQL via Supabase)
# -----------------------------------------------------------------------------
#  DATABASE_URL      = connexion utilisée par l'application (mode "pooler")
#  DIRECT_URL        = connexion directe utilisée pour les migrations Prisma
#
#  Où trouver ces valeurs :
#    Supabase → ton projet → Settings (roue crantée) → Database →
#    section "Connection string" → onglet "URI".
#    - DATABASE_URL : copie l'URL "Transaction pooler" (port 6543)
#    - DIRECT_URL   : copie l'URL "Direct connection"  (port 5432)
#    Remplace [YOUR-PASSWORD] par le mot de passe choisi à la création du projet.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.xxxxxxxx:MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"


# -----------------------------------------------------------------------------
#  2. AUTHENTIFICATION (NextAuth.js)
# -----------------------------------------------------------------------------
#  NEXTAUTH_URL      = l'adresse de ton site.
#    - En local         : http://localhost:3000
#    - En production     : https://ton-site.vercel.app (URL donnée par Vercel)
#
#  NEXTAUTH_SECRET   = une longue clé secrète aléatoire (sécurise les sessions).
#    Génère-la avec cette commande dans un terminal :
#        openssl rand -base64 32
#    ...ou via le site https://generate-secret.vercel.app/32
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="colle-ici-une-longue-cle-aleatoire"


# -----------------------------------------------------------------------------
#  3. COMPTE ADMINISTRATEUR
# -----------------------------------------------------------------------------
#  C'est l'identifiant et le mot de passe pour te connecter à l'espace admin
#  (page /admin). Le compte est créé automatiquement au lancement du "seed".
#
#  ⚠️  Choisis un mot de passe SOLIDE (12+ caractères, lettres+chiffres+symboles).
#  Tu pourras te connecter sur : https://ton-site.vercel.app/admin
# -----------------------------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-moi-immédiatement"


# -----------------------------------------------------------------------------
#  4. (OPTIONNEL) WARCRAFT LOGS — synchro auto des pulls / % sur la Progression
# -----------------------------------------------------------------------------
#  Permet d'afficher automatiquement le nombre de pulls et le meilleur % de vie
#  atteint sur les boss en cours de progression (World of Warcraft uniquement).
#
#  Laisse ces deux variables VIDES pour désactiver la synchro (la progression
#  fonctionne très bien sans).
#
#  Où trouver ces valeurs :
#    1. Va sur https://www.warcraftlogs.com/api/clients/
#    2. Clique « Create Client », donne un nom (ex : "Site Absolution")
#    3. Mets n'importe quelle URL en "Redirect URL" (ex : https://ton-site.vercel.app)
#    4. Copie le Client ID et le Client Secret affichés.
#
#  Ensuite, renseigne l'identité de la guilde (région / royaume / nom) et les
#  IDs de zone/boss directement dans l'admin (pas ici).
# -----------------------------------------------------------------------------
WCL_CLIENT_ID=""
WCL_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
#  5. (OPTIONNEL) UPLOAD D'IMAGES — Vercel Blob
# -----------------------------------------------------------------------------
#  Permet de téléverser des images depuis l'admin (logos, couvertures, boss…)
#  au lieu de coller une URL. Laisse vide pour désactiver (le champ URL reste
#  utilisable).
#
#  Où trouver cette valeur :
#    Vercel → ton projet → onglet "Storage" → "Create Database" → "Blob".
#    Le token BLOB_READ_WRITE_TOKEN est alors ajouté automatiquement aux
#    variables d'environnement du projet (rien à copier à la main en prod).
#    En local : Storage → ton store Blob → onglet ".env.local" pour le copier.
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""


# -----------------------------------------------------------------------------
#  6. (OPTIONNEL) NOTIFICATIONS DISCORD — webhook entrant
# -----------------------------------------------------------------------------
#  Le site envoie un message dans un salon Discord à chaque nouvelle
#  candidature. Laisse vide pour désactiver.
#
#  Où trouver cette valeur :
#    Discord → Paramètres du salon → Intégrations → Webhooks → "Nouveau webhook"
#    → copie l'URL du webhook.
#  (Voir docs/BOT.md pour l'intégration complète du futur bot.)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=""


# -----------------------------------------------------------------------------
#  7. (OPTIONNEL) ANTI-SPAM / ANTI BRUTE-FORCE — Upstash Redis
# -----------------------------------------------------------------------------
#  Sans ça, la limitation de débit (connexion, inscription, candidatures) est
#  stockée en mémoire et devient inefficace sur Vercel (plusieurs instances).
#  Upstash Redis la rend RÉELLE et partagée. Laisse vide pour le mode mémoire.
#
#  Où trouver ces valeurs :
#    Vercel → projet → Storage → Create Database → "Upstash for Redis", puis
#    connecte-la au projet : les variables ci-dessous sont ajoutées automatiquement.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# -----------------------------------------------------------------------------
#  8. (OPTIONNEL) BOT DISCORD — liaison site → bot
# -----------------------------------------------------------------------------
#  Permet au site de prévenir le bot instantanément (event de calendrier publié,
#  etc.). Laisse vide si le bot n'est pas déployé.
#
#  BOT_URL          = URL publique du bot sur Railway (ex : https://xxx.up.railway.app)
#  BOT_HTTP_SECRET  = le MÊME secret que celui configuré côté bot
# -----------------------------------------------------------------------------
BOT_URL=""
BOT_HTTP_SECRET=""


# -----------------------------------------------------------------------------
#  9. (OPTIONNEL) CONNEXION DISCORD — inscription aux events depuis le site
# -----------------------------------------------------------------------------
#  Permet à un membre de relier son compte Discord pour s'inscrire aux
#  événements depuis le site (synchronisé avec les boutons Discord).
#
#  Dans le Developer Portal Discord → ton application → OAuth2 :
#   - DISCORD_CLIENT_ID     = l'Application ID (le même que pour le bot)
#   - DISCORD_CLIENT_SECRET = OAuth2 → Client Secret (clique « Reset Secret »)
#   - Ajoute l'URL de redirection (OAuth2 → Redirects) :
#       https://TON-SITE/api/discord/callback
# -----------------------------------------------------------------------------
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
#  10. (OPTIONNEL) ALERTES TWITCH — overlay /overlay/alert (follows, subs, raids)
# -----------------------------------------------------------------------------
#  Affiche des alertes animées en temps réel pendant le stream, via Twitch
#  EventSub (webhook). Configuration dans Admin → Overlays Stream.
#
#  1. Crée une application sur https://dev.twitch.tv/console/apps
#     - URL de redirection OAuth : https://TON-SITE/api/twitch/callback
#  2. Copie l'identifiant et le secret client ci-dessous.
#  3. TWITCH_EVENTSUB_SECRET : invente une longue chaîne aléatoire (10–100
#     caractères) ; elle sécurise le webhook EventSub.
#  4. Dans l'admin, clique « Connecter ma chaîne Twitch » puis « Créer les
#     abonnements ». (NEXTAUTH_URL doit pointer vers l'URL publique du site.)
# -----------------------------------------------------------------------------
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_EVENTSUB_SECRET=""
