# =============================================================================
#  FICHIER DE CONFIGURATION — Site de la guilde Absolution
# =============================================================================
#
#  COMMENT UTILISER CE FICHIER :
#  1. Fais une COPIE de ce fichier et nomme-la ".env" (sans le ".example")
#  2. Remplis chaque valeur ci-dessous en suivant les explications
#  3. Ne partage JAMAIS ton fichier ".env" : il contient des mots de passe
#
#  (Le README explique pas-à-pas où trouver chacune de ces valeurs.)
# =============================================================================


# -----------------------------------------------------------------------------
#  1. BASE DE DONNÉES (PostgreSQL via Supabase)
# -----------------------------------------------------------------------------
#  DATABASE_URL      = connexion utilisée par l'application (mode "pooler")
#  DIRECT_URL        = connexion directe utilisée pour les migrations Prisma
#
#  Où trouver ces valeurs :
#    Supabase → ton projet → Settings (roue crantée) → Database →
#    section "Connection string" → onglet "URI".
#    - DATABASE_URL : copie l'URL "Transaction pooler" (port 6543)
#    - DIRECT_URL   : copie l'URL "Direct connection"  (port 5432)
#    Remplace [YOUR-PASSWORD] par le mot de passe choisi à la création du projet.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.xxxxxxxx:MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"


# -----------------------------------------------------------------------------
#  2. AUTHENTIFICATION (NextAuth.js)
# -----------------------------------------------------------------------------
#  NEXTAUTH_URL      = l'adresse de ton site.
#    - En local         : http://localhost:3000
#    - En production     : https://ton-site.vercel.app (URL donnée par Vercel)
#
#  NEXTAUTH_SECRET   = une longue clé secrète aléatoire (sécurise les sessions).
#    Génère-la avec cette commande dans un terminal :
#        openssl rand -base64 32
#    ...ou via le site https://generate-secret.vercel.app/32
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="colle-ici-une-longue-cle-aleatoire"


# -----------------------------------------------------------------------------
#  3. COMPTE ADMINISTRATEUR
# -----------------------------------------------------------------------------
#  C'est l'identifiant et le mot de passe pour te connecter à l'espace admin
#  (page /admin). Le compte est créé automatiquement au lancement du "seed".
#
#  ⚠️  Choisis un mot de passe SOLIDE (12+ caractères, lettres+chiffres+symboles).
#  Tu pourras te connecter sur : https://ton-site.vercel.app/admin
# -----------------------------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-moi-immédiatement"


# -----------------------------------------------------------------------------
#  4. (OPTIONNEL) WARCRAFT LOGS — synchro auto des pulls / % sur la Progression
# -----------------------------------------------------------------------------
#  Permet d'afficher automatiquement le nombre de pulls et le meilleur % de vie
#  atteint sur les boss en cours de progression (World of Warcraft uniquement).
#
#  Laisse ces deux variables VIDES pour désactiver la synchro (la progression
#  fonctionne très bien sans).
#
#  Où trouver ces valeurs :
#    1. Va sur https://www.warcraftlogs.com/api/clients/
#    2. Clique « Create Client », donne un nom (ex : "Site Absolution")
#    3. Mets n'importe quelle URL en "Redirect URL" (ex : https://ton-site.vercel.app)
#    4. Copie le Client ID et le Client Secret affichés.
#
#  Ensuite, renseigne l'identité de la guilde (région / royaume / nom) et les
#  IDs de zone/boss directement dans l'admin (pas ici).
# -----------------------------------------------------------------------------
WCL_CLIENT_ID=""
WCL_CLIENT_SECRET=""
