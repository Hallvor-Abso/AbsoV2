// =============================================================================
//  SCHÉMA DE LA BASE DE DONNÉES — Guilde Absolution
// =============================================================================
//  Ce fichier décrit TOUTES les tables du site. Si tu modifies une table ici,
//  pense à lancer une migration : `npm run db:migrate`
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // connexion applicative (pooler)
  directUrl = env("DIRECT_URL")   // connexion directe (migrations)
}

// -----------------------------------------------------------------------------
//  UTILISATEUR
//  Comptes des visiteurs inscrits + comptes d'administration.
//  - role : niveau de base (Visiteur / Membre / Admin / Super Admin)
//  - adminGames : jeux dont l'utilisateur est admin (= « Admin WoW », « Admin SWTOR »…)
//    Permet de gérer n'importe quel futur jeu sans changer le code.
// -----------------------------------------------------------------------------
model User {
  id           String   @id @default(cuid())
  username     String?  @unique // identifiant du super-admin « bootstrap » (.env)
  email        String?  @unique // email de connexion des comptes inscrits
  displayName  String? // pseudo affiché
  discord      String? // identifiant Discord (texte libre, informatif)
  discordId    String?  @unique // ID Discord réel (rempli via « Connexion Discord »)
  passwordHash String
  role         Role     @default(VISITEUR)
  adminGames   Game[]   @relation("GameAdmins")
  applications Application[]
  createdAt    DateTime @default(now())
}

enum Role {
  VISITEUR    // inscrit : Accueil, Progression, News, Recrutement
  MEMBRE      // membre de la guilde : tout le site public (dont Calendrier)
  ADMIN       // panel admin complet sauf « Contenu du site »
  SUPER_ADMIN // accès total
}

// -----------------------------------------------------------------------------
//  JEU (World of Warcraft, SWTOR, futurs jeux...)
//  Si `isActive` est false, le jeu disparaît ENTIÈREMENT du site public.
// -----------------------------------------------------------------------------
model Game {
  id              String   @id @default(cuid())
  name            String // "World of Warcraft"
  slug            String   @unique // "wow" — utilisé dans les URLs
  logoUrl         String? // logo du jeu
  coverImageUrl   String? // art officiel (affiché assombri sur les cartes)
  color           String   @default("#4A9EFF") // couleur d'accent du jeu
  isActive        Boolean  @default(true) // visible sur le site public ?
  status          GameStatus @default(ACTIVE) // ACTIVE = jouable, UPCOMING = à venir
  order           Int      @default(0) // ordre d'affichage

  // Salons Discord où le bot publie, pour CE jeu (un par jeu).
  discordCalendarChannelId    String? // calendrier / événements
  discordRecruitmentChannelId String? // salon unique des candidatures (mode simple)
  discordRecruitmentCategoryId String? // catégorie : le bot crée un salon « candid-pseudo » dedans

  // Tag des rôles Discord du jeu (ex. « WOW », « SWTOR »). Le bot pingue alors
  // « Officier WOW », « Roster WOW », etc. Vide → déduit du slug en majuscules.
  discordRoleTag  String?

  raidTiers       RaidTier[]
  news            News[]
  recruitmentRoles RecruitmentRole[]
  recruitmentSlots RecruitmentSlot[]
  recruitmentFields RecruitmentField[]
  applications    Application[]
  memberMains     MemberMain[]
  events          Event[]
  admins          User[]    @relation("GameAdmins") // admins propres à ce jeu

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum GameStatus {
  ACTIVE   // jeu sur lequel la guilde est active
  UPCOMING // jeu prévu / à venir
}

// -----------------------------------------------------------------------------
//  TIER DE RAID (ex : "Nerub-ar Palace", "Liberation of Undermine")
//  Regroupe plusieurs boss. Appartient à un jeu.
// -----------------------------------------------------------------------------
model RaidTier {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0) // les tiers récents en premier
  expansion String? // nom de l'extension / contenu (ex. « The War Within »)
  zoneId    Int? // ID de la zone Warcraft Logs (pour la synchro auto des pulls/%)
  timerDone Boolean  @default(false) // SWTOR : Succès « timer » de l'opération validé
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    String
  bosses    Boss[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
//  BOSS — un combat de raid avec son statut de progression.
// -----------------------------------------------------------------------------
model Boss {
  id            String     @id @default(cuid())
  name          String
  status        BossStatus @default(UNTESTED)
  firstKillDate DateTime? // date du premier kill (si tué)
  imageUrl      String? // visuel du boss (éditable depuis l'admin)
  encounterId   Int? // ID de rencontre Warcraft Logs (pour la synchro auto)
  order         Int        @default(0) // ordre dans le tier
  tier          RaidTier   @relation(fields: [tierId], references: [id], onDelete: Cascade)
  tierId        String

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

enum BossStatus {
  KILLED      // tué
  PROGRESSING // en progression
  UNTESTED    // non tenté
}

// -----------------------------------------------------------------------------
//  NEWS / ARTICLE — contenu rédigé via l'éditeur Tiptap (HTML riche).
// -----------------------------------------------------------------------------
model News {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique // identifiant dans l'URL
  excerpt     String? // résumé court affiché dans la grille
  content     String // HTML riche produit par l'éditeur
  imageUrl    String? // image de couverture
  imageFit    String     @default("cover") // "cover" (rogne) ou "contain" (image entière)
  featured    Boolean    @default(false) // article mis « À la Une »
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime? // date de publication
  game        Game?      @relation(fields: [gameId], references: [id], onDelete: SetNull)
  gameId      String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum NewsStatus {
  DRAFT     // brouillon (invisible au public)
  PUBLISHED // publié
}

// -----------------------------------------------------------------------------
//  RÔLE DE RECRUTEMENT (Tank, Heal, DPS Distance... nommage libre).
//  Regroupe des classes/spécialisations. Peut exister sans aucune classe.
// -----------------------------------------------------------------------------
model RecruitmentRole {
  id          String   @id @default(cuid())
  name        String // libellé libre du rôle (catégorie : Tank, Heal, DPS...)
  description String? // description de la catégorie, affichée dans son cadre
  order       Int      @default(0)
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([gameId, name]) // un rôle est unique par jeu
}

// -----------------------------------------------------------------------------
//  POSTE DE RECRUTEMENT — une classe/spécialisation recherchée, avec son statut.
//  `role` correspond au nom d'un RecruitmentRole du même jeu.
// -----------------------------------------------------------------------------
model RecruitmentSlot {
  id        String     @id @default(cuid())
  role      String // "Tank", "Heal", "DPS Distance"...
  className String // "Guerrier", "Sage"...
  status    SlotStatus @default(OPEN)
  note      String? // précision optionnelle
  order     Int        @default(0)
  game      Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    String

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum SlotStatus {
  OPEN    // ouvert
  LIMITED // limité (high-end only)
  CLOSED  // fermé
}

// -----------------------------------------------------------------------------
//  CHAMP DE FORMULAIRE — un champ personnalisable du formulaire de candidature,
//  propre à un jeu. Permet d'adapter le formulaire selon le jeu (constructeur).
// -----------------------------------------------------------------------------
model RecruitmentField {
  id          String           @id @default(cuid())
  key         String // identifiant stable (slug), clé dans Application.answers
  label       String
  type        RecruitFieldType @default(TEXT)
  placeholder String?
  helpText    String?
  required    Boolean          @default(false)
  options     String[]         @default([]) // valeurs proposées pour les listes déroulantes (SELECT)
  order       Int              @default(0)
  game        Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId      String

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([gameId, key])
}

enum RecruitFieldType {
  TEXT     // texte court
  TEXTAREA // texte long
  URL      // lien
  NUMBER   // nombre
  SELECT   // liste déroulante
}

// -----------------------------------------------------------------------------
//  CANDIDATURE — soumise via le formulaire public de recrutement.
// -----------------------------------------------------------------------------
model Application {
  id            String            @id @default(cuid())
  pseudo        String
  discord       String? // pseudo Discord du candidat (pour le recontacter)

  // Réponses au formulaire personnalisé du jeu : tableau [{ label, value }].
  answers       Json?

  // Anciennes colonnes fixes (formulaire WoW historique). Conservées en
  // nullable pour l'affichage des candidatures antérieures au constructeur.
  characterId   String?
  className     String?
  role          String?
  server        String?
  experience    String?
  availability  String?
  logsUrl       String?
  motivation    String?
  status        ApplicationStatus @default(PENDING)
  internalNotes String? // notes internes (admin only)
  discordChannelId String? // salon « candid-pseudo » créé par le bot (mode catégorie)

  // Suivi côté candidat (connexion obligatoire pour postuler).
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId        String?
  lastOfficerMessageAt DateTime? // dernier message d'un officier dans le salon
  candidateSeenAt      DateTime? // dernière consultation par le candidat

  game          Game?             @relation(fields: [gameId], references: [id], onDelete: SetNull)
  gameId        String?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum ApplicationStatus {
  PENDING    // en attente
  DISCUSSING // en discussion
  ACCEPTED   // acceptée
  REJECTED   // refusée
}

// -----------------------------------------------------------------------------
//  ÉVÉNEMENT DU CALENDRIER (raid, soirée, événement spécial...).
// -----------------------------------------------------------------------------
model Event {
  id               String    @id @default(cuid())
  title            String
  description      String?
  startDate        DateTime
  endDate          DateTime?
  type             String    @default("RAID") // RAID, EVENT, OTHER
  game             Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId           String

  // Synchro Discord (bot) : salon + message à mettre à jour quand les
  // inscriptions changent.
  discordChannelId String?
  discordMessageId String?

  // Rappels envoyés en MP (horodatés pour ne pas les renvoyer).
  reminder24hSentAt DateTime?
  reminder1hSentAt  DateTime?

  signups          EventSignup[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// -----------------------------------------------------------------------------
//  INSCRIPTION À UN ÉVÉNEMENT (RSVP) — alimentée par le site (via Discord OAuth)
//  ET par les boutons Discord. L'identité pivot est l'ID Discord, ce qui
//  déduplique automatiquement les inscriptions des deux côtés.
// -----------------------------------------------------------------------------
model EventSignup {
  id          String       @id @default(cuid())
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String
  discordId   String // identité pivot (site connecté via Discord OU clic Discord)
  displayName String // pseudo affiché (dénormalisé)
  status      SignupStatus @default(GOING)
  source      String       @default("discord") // "site" ou "discord" (informatif)

  // Classe/spé/rôle au moment de l'inscription (figés pour l'affichage).
  role        String? // TANK / HEAL / DPS
  classId     String? // identifiant de classe (ex. mage, juggernaut)
  className   String? // libellé de classe
  spec        String? // libellé de spécialisation

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([eventId, discordId])
}

// -----------------------------------------------------------------------------
//  MAIN D'UN MEMBRE — sa classe/spé principale PAR JEU, mémorisée et réutilisée
//  aux inscriptions (partagé site + Discord via discordId). Modifiable.
// -----------------------------------------------------------------------------
model MemberMain {
  id        String   @id @default(cuid())
  discordId String // identité pivot (même clé que EventSignup)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    String
  role      String // TANK / HEAL / DPS (déduit de la spé)
  classId   String // identifiant de classe (ex. mage)
  className String // libellé de classe
  specId    String // identifiant de spé
  spec      String // libellé de spé

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([discordId, gameId])
}

// -----------------------------------------------------------------------------
//  JOURNAL D'AUDIT — trace légère des actions admin sensibles.
// -----------------------------------------------------------------------------
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String? // id du compte qui a agi
  actorName String // pseudo (dénormalisé)
  action    String // libellé court de l'action
  detail    String? // précision (cible, ancienne/nouvelle valeur…)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum SignupStatus {
  GOING    // présent
  MAYBE    // peut-être
  DECLINED // absent
}

// -----------------------------------------------------------------------------
//  CONTENU STATIQUE (textes de la homepage, logo de guilde...).
//  Système clé/valeur simple, éditable depuis l'admin.
//  Ex : key="hero.tagline", value="Progression. Cohésion. Excellence."
// -----------------------------------------------------------------------------
model SiteContent {
  key       String   @id // identifiant du texte
  value     String // contenu
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
//  ALERTES DE STREAM — file d'attente des événements Twitch (follows, subs,
//  raids). Alimentée par le webhook EventSub (et les tests admin) ; consommée
//  par l'overlay /overlay/alert qui interroge régulièrement les nouvelles
//  entrées. Les anciennes alertes sont purgées automatiquement.
// -----------------------------------------------------------------------------
model StreamAlert {
  id        Int       @id @default(autoincrement())
  type      AlertType
  username  String    @default("")
  message   String    @default("")
  amount    Int       @default(0) // mois (resub), nb d'abos offerts, ou viewers (raid)
  tier      String    @default("") // niveau d'abonnement Twitch (1000/2000/3000)
  createdAt DateTime  @default(now())

  @@index([createdAt])
}

enum AlertType {
  FOLLOW
  SUB
  RESUB
  SUBGIFT
  RAID
  TEST
}
